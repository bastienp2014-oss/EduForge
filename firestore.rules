rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -----------------------------------------------------------------------------
    // HELPERS
    // -----------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.get('role', '') == 'superadmin';
    }
    
    function isTenantMember(tenantId) {
      return isSignedIn() && getUserTenantId() == tenantId;
    }

    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) && (request.auth.token.get('role', '') == 'admin' || request.auth.token.get('role', '') == 'owner');
    }
    
    function isTenantCreator(tenantId) {
      return isTenantMember(tenantId) && request.auth.token.get('role', '') == 'creator';
    }

    function getUserTenantId() {
      return ('tenantId' in request.auth.token) 
        ? request.auth.token.tenantId 
        : (exists(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)) 
          ? get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data.get('tenantId', 'eduforge')
          : 'eduforge');
    }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidString(val, maxLength) {
      return val is string && val.size() <= maxLength;
    }

    function isValidNumber(val, minVal) {
      return (val is number || val is int || val is float) && val >= minVal;
    }

    function isValidArray(val, maxLen) {
      return val is list && val.size() <= maxLen;
    }

    function canAuthorHierarchy(tenantId) {
      return isAdmin() || isTenantAdmin(tenantId) || isTenantCreator(tenantId);
    }

    function isValidHierarchyNode(tenantId, nodeId) {
      return isValidId(nodeId)
             && incoming().id == nodeId
             && incoming().tenantId == tenantId
             && isValidString(incoming().title, 200) && incoming().title.size() > 0
             && isValidNumber(incoming().order, 0)
             && incoming().status in ['draft', 'published']
             && isValidNumber(incoming().digestVersion, 1)
             && isValidString(incoming().contextDigest, 4000);
    }

    // -----------------------------------------------------------------------------
    // DENY BY DEFAULT
    // -----------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------------
    // TENANTS (SaaS B2B configs)
    // -----------------------------------------------------------------------------
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTenantAdmin(tenantId);
      
      // Members subcollection (managed via Admin API in server.ts)
      match /members/{userId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow write: if false;
      }

      // Configuration subcollection
      match /configuration/{document=**} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isTenantAdmin(tenantId);
      }

      // Scenarios subcollection
      match /scenarios/{document=**} {
        allow read: if isAdmin() || isTenantMember(tenantId) || (isSignedIn() && resource.data.statut == 'active');
        allow write: if isAdmin() || isTenantAdmin(tenantId) || isTenantCreator(tenantId);
      }

      // Secrets subcollection (BYOK API keys, encrypted). Server accesses this via the
      // Admin SDK, which bypasses these rules — this block is defense-in-depth against
      // any future client-side read/write attempt.
      match /secrets/{document=**} {
        allow read, write: if isAdmin() || isTenantAdmin(tenantId);
      }

      // -----------------------------------------------------------------------------
      // HIERARCHY: programs -> courses -> chapters -> lessons -> activities
      // (plan.md Phase 1, item #1). Nœud terminal = `activities` — pas de collection
      // ni de schéma `questions` ici ; différé (voir PRD, décision D3).
      //
      // Requêtes de liste : une condition `status == 'published'` dans `allow read`
      // fait échouer TOUTE la requête si elle peut retourner un brouillon — Firestore
      // évalue la règle contre chaque résultat potentiel, pas seulement ceux qu'un
      // client naïf attend. Un client apprenant DOIT donc filtrer lui-même avec
      // `.where('status', '==', 'published')` ; cette règle ne filtre pas les
      // brouillons pour lui dans une requête non scopée.
      //
      // Pas de suppression en cascade : Firestore ne supprime pas les sous-collections
      // d'un document supprimé. Supprimer un `programs/{programId}` NE supprime PAS
      // ses `courses`/`chapters`/`lessons`/`activities` — elles deviennent orphelines,
      // toujours accessibles par chemin direct. `delete` est donc restreint à
      // isAdmin()/isTenantAdmin() (créateurs exclus) à tous les niveaux, comme garde-
      // fou volontaire. Un job de cascade est hors portée de cet item.
      // -----------------------------------------------------------------------------
      match /programs/{programId} {
        allow read: if isAdmin()
                       || isTenantAdmin(tenantId)
                       || isTenantCreator(tenantId)
                       || (isTenantMember(tenantId) && existing().status == 'published');

        allow create: if canAuthorHierarchy(tenantId)
                         && isValidHierarchyNode(tenantId, programId);

        allow update: if canAuthorHierarchy(tenantId)
                         && isValidHierarchyNode(tenantId, programId)
                         && incoming().tenantId == existing().tenantId
                         && incoming().digestVersion >= existing().digestVersion;

        allow delete: if isAdmin() || isTenantAdmin(tenantId);

        match /courses/{courseId} {
          allow read: if isAdmin()
                         || isTenantAdmin(tenantId)
                         || isTenantCreator(tenantId)
                         || (isTenantMember(tenantId) && existing().status == 'published');

          allow create: if canAuthorHierarchy(tenantId)
                           && isValidHierarchyNode(tenantId, courseId);

          allow update: if canAuthorHierarchy(tenantId)
                           && isValidHierarchyNode(tenantId, courseId)
                           && incoming().tenantId == existing().tenantId
                           && incoming().digestVersion >= existing().digestVersion;

          allow delete: if isAdmin() || isTenantAdmin(tenantId);

          match /chapters/{chapterId} {
            allow read: if isAdmin()
                           || isTenantAdmin(tenantId)
                           || isTenantCreator(tenantId)
                           || (isTenantMember(tenantId) && existing().status == 'published');

            allow create: if canAuthorHierarchy(tenantId)
                             && isValidHierarchyNode(tenantId, chapterId);

            allow update: if canAuthorHierarchy(tenantId)
                             && isValidHierarchyNode(tenantId, chapterId)
                             && incoming().tenantId == existing().tenantId
                             && incoming().digestVersion >= existing().digestVersion;

            allow delete: if isAdmin() || isTenantAdmin(tenantId);

            match /lessons/{lessonId} {
              allow read: if isAdmin()
                             || isTenantAdmin(tenantId)
                             || isTenantCreator(tenantId)
                             || (isTenantMember(tenantId) && existing().status == 'published');

              allow create: if canAuthorHierarchy(tenantId)
                               && isValidHierarchyNode(tenantId, lessonId);

              allow update: if canAuthorHierarchy(tenantId)
                               && isValidHierarchyNode(tenantId, lessonId)
                               && incoming().tenantId == existing().tenantId
                               && incoming().digestVersion >= existing().digestVersion;

              allow delete: if isAdmin() || isTenantAdmin(tenantId);

              match /activities/{activityId} {
                allow read: if isAdmin()
                               || isTenantAdmin(tenantId)
                               || isTenantCreator(tenantId)
                               || (isTenantMember(tenantId) && existing().status == 'published');

                allow create: if canAuthorHierarchy(tenantId)
                                 && isValidHierarchyNode(tenantId, activityId);

                allow update: if canAuthorHierarchy(tenantId)
                                 && isValidHierarchyNode(tenantId, activityId)
                                 && incoming().tenantId == existing().tenantId
                                 && incoming().digestVersion >= existing().digestVersion;

                allow delete: if isAdmin() || isTenantAdmin(tenantId);
              }
            }
          }
        }
      }
    }

    // -----------------------------------------------------------------------------
    // UTILISATEURS
    // -----------------------------------------------------------------------------
    match /utilisateurs/{userId} {
      // READ : Uniquement le propriétaire ou admin
      allow get: if (isOwner(userId) && isValidId(userId)) || isAdmin() || (('tenantId' in existing()) && isTenantAdmin(existing().tenantId));
      allow list: if isAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
      
      // CREATE / UPDATE
      allow create: if isOwner(userId) && isValidId(userId)
                    && !('isAdmin' in incoming()) // Interdiction absolue d'escalade
                    && !('piasses' in incoming() && incoming().piasses != 0)
                    && !('xp' in incoming() && incoming().xp != 0)
                    && incoming().tenantId is string
                    // Validation simple
                    && (!('streakCount' in incoming()) || incoming().streakCount == null || isValidNumber(incoming().streakCount, 0))
                    && (!('longestStreak' in incoming()) || incoming().longestStreak == null || isValidNumber(incoming().longestStreak, 0))
                    && (!('lastActiveDay' in incoming()) || incoming().lastActiveDay == null || incoming().lastActiveDay is string)
                    && (!('surnom' in incoming()) || incoming().surnom == null || isValidString(incoming().surnom, 100))
                    && (!('motsDebloques' in incoming()) || incoming().motsDebloques == null || isValidArray(incoming().motsDebloques, 2000))
                    && (!('derniereMiseAJour' in incoming()) || incoming().derniereMiseAJour == null || incoming().derniereMiseAJour is timestamp);
                    
      allow update: if isOwner(userId) && isValidId(userId)
                    && !incoming().diff(existing()).affectedKeys().hasAny(['isAdmin', 'piasses', 'xp', 'isPremium', 'subscriptionPlan', 'entitlements'])
                    // Validation de types
                    && (!('streakCount' in incoming()) || incoming().streakCount == null || isValidNumber(incoming().streakCount, 0))
                    && (!('longestStreak' in incoming()) || incoming().longestStreak == null || isValidNumber(incoming().longestStreak, 0))
                    && (!('lastActiveDay' in incoming()) || incoming().lastActiveDay == null || incoming().lastActiveDay is string)
                    && (!('surnom' in incoming()) || incoming().surnom == null || isValidString(incoming().surnom, 100))
                    && (!('motsDebloques' in incoming()) || incoming().motsDebloques == null || isValidArray(incoming().motsDebloques, 2000))
                    && (!('derniereMiseAJour' in incoming()) || incoming().derniereMiseAJour == null || incoming().derniereMiseAJour is timestamp);

      match /srs/{itemId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
    }

    // -----------------------------------------------------------------------------
    // NOTES PRIVÉES
    // -----------------------------------------------------------------------------
    match /notes/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId)
                    && incoming().tenantId is string
                    && incoming().userId == userId
                    && incoming().noteText is string
                    && incoming().noteText.size() <= 100000
                    && (!('lastUpdated' in incoming()) || incoming().lastUpdated == null || incoming().lastUpdated is timestamp);
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // -----------------------------------------------------------------------------
    // CLASSEMENT
    // -----------------------------------------------------------------------------
    match /classement/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isOwner(userId) && isValidId(userId)
                    && incoming().tenantId is string
                    && (!('scoreTotal' in incoming()) || incoming().scoreTotal == null || isValidNumber(incoming().scoreTotal, 0))
                    && (!('surnom' in incoming()) || incoming().surnom == null || isValidString(incoming().surnom, 100))
                    && (!('derniereMiseAJour' in incoming()) || incoming().derniereMiseAJour is timestamp);
      allow update: if isOwner(userId) && isValidId(userId)
                    && (!('scoreTotal' in incoming()) || incoming().scoreTotal == null || isValidNumber(incoming().scoreTotal, 0))
                    && (!('surnom' in incoming()) || incoming().surnom == null || isValidString(incoming().surnom, 100))
                    && (!('derniereMiseAJour' in incoming()) || incoming().derniereMiseAJour is timestamp);
    }
    // -----------------------------------------------------------------------------
    // COURSES & BUNDLES (Creator Hub)
    // -----------------------------------------------------------------------------
    match /courses/{courseId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.tenantId == getUserTenantId());
      allow create: if (isAdmin() || isTenantCreator(incoming().tenantId) || isTenantAdmin(incoming().tenantId))
                    && incoming().tenantId == getUserTenantId();
      allow update: if (isAdmin() || isTenantCreator(existing().tenantId) || isTenantAdmin(existing().tenantId))
                    && incoming().tenantId == existing().tenantId;
      allow delete: if isAdmin() || isTenantAdmin(existing().tenantId) || isTenantCreator(existing().tenantId);
    }

    match /bundles/{bundleId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.tenantId == getUserTenantId());
      allow create: if (isAdmin() || isTenantCreator(incoming().tenantId) || isTenantAdmin(incoming().tenantId))
                    && incoming().tenantId == getUserTenantId();
      allow update: if (isAdmin() || isTenantCreator(existing().tenantId) || isTenantAdmin(existing().tenantId))
                    && incoming().tenantId == existing().tenantId;
      allow delete: if isAdmin() || isTenantAdmin(existing().tenantId) || isTenantCreator(existing().tenantId);
    }
  }
}

